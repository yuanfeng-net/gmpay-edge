{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "gmpay-edge",
	"main": "src/server-entry.ts",
	"compatibility_date": "2026-07-01",
	"compatibility_flags": ["nodejs_compat"],
	"placement": { "mode": "smart" },
	"observability": { "enabled": true },
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "gmpay-edge",
			"migrations_dir": "drizzle"
		}
	],
	"r2_buckets": [{ "binding": "FILES", "bucket_name": "gmpay-edge-files" }],
	"kv_namespaces": [
		{ "binding": "CACHE" }
	],
	"queues": {
		"producers": [
			{ "binding": "WEBHOOK_QUEUE", "queue": "gmpay-edge-webhooks" },
			{ "binding": "PAYMENT_QUEUE", "queue": "gmpay-edge-payments" }
		],
		"consumers": [
			{
				"queue": "gmpay-edge-webhooks",
				"max_batch_size": 10,
				"max_batch_timeout": 1,
				"max_concurrency": 5,
				"max_retries": 8,
				"retry_delay": 15,
				"dead_letter_queue": "gmpay-edge-webhooks-dlq"
			},
			{
				"queue": "gmpay-edge-payments",
				"max_batch_size": 10,
				"max_batch_timeout": 1,
				"max_concurrency": 2,
				"max_retries": 5,
				"retry_delay": 15,
				"dead_letter_queue": "gmpay-edge-payments-dlq"
			}
		]
	},
	"triggers": { "crons": ["* * * * *"] }
}
